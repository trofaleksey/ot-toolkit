    "settings.disclosure.backup.message": {
      "comment": "Backup limitation detail.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Saved boards stay on this device only. They are excluded from device and iCloud backups, so they will not appear on a new or restored device."
          }
        }
      }
    },
    "settings.disclosure.backup.title": {
      "comment": "Backup limitation heading.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Boards do not transfer between devices"
          }
        }
      }
    },
    "settings.disclosure.naming.message": {
      "comment": "Naming guidance detail.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use activity or routine names rather than a child's name. Initials and nicknames can still identify a child."
          }
        }
      }
    },
    "settings.disclosure.naming.title": {
      "comment": "Naming guidance heading.",
      "extractionState": "manual",
