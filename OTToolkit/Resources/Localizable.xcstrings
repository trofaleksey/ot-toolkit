          }
        }
      }
    },
    "settings.disclosure.timer.message": {
      "comment": "Timer lifecycle limitation detail.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Force quitting the app, a device restart, or the system reclaiming memory ends a running timer. The app reopens with no timer running and does not alert you in the background."
          }
        }
      }
    },
    "settings.disclosure.timer.title": {
      "comment": "Timer lifecycle limitation heading.",
